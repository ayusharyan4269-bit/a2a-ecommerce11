// Prisma schema for A2A Agentic Commerce (Web3 + Secure Design)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id            String   @id @default(cuid())

  // Basic Info
  service       String
  type          String
  description   String

  // Web3 Pricing (store in wei as string for precision)
  price         String

  // Seller Identity (wallet-based, not username)
  sellerWallet  String

  // IPFS CID (encrypted credentials stored off-chain)
  ipfsHash      String

  // Optional proof (screenshot URL / demo link)
  proof         String?

  // Reputation system
  reputation    Int      @default(0)

  // Status tracking
  isSold        Boolean  @default(false)

  // Timestamp
  createdAt     DateTime @default(now())
}

model DecentralizedKey {
  cid            String   @id

  // Encrypted AES key (used to decrypt IPFS data)
  encryptedKey   String

  // Seller wallet
  sellerWallet   String

  // Timestamp
  createdAt      DateTime @default(now())
}