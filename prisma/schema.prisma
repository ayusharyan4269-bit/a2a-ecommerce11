// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id            String   @id @default(cuid())
  service       String
  type          String
  price         Float
  description   String
  seller        String
  
  // Sensitive Data
  username      String?
  password      String?
  notes         String?
  
  // Cryptographic Properties
  signature     String?
  zkCommitment  String?
  ipfsHash      String?   // IPFS CID from Pinata — links wallet address to stored item

  // Date tracking matches existing DB format
  timestamp     Float
  createdAt     String
}
